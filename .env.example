# ======== POSTGRES CONFIG ========
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_postgres_password
POSTGRES_DB=adk_db

# ======== REDIS CONFIG ========
REDIS_PASSWORD=your_strong_redis_password

# ======== BACKEND CONFIG ========
# Used for backend CORS and JWT
FRONTEND_URL=https://your-frontend-domain.com
ENCRYPTION_KEY=your-32-character-encryption-key-for-prod
JWT_SECRET=your-jwt-secret-key-for-prod-secure-random

# ======== DOCKER PORTS ========
# Map nginx container out to port 80? Adjust if you have a proxy
FRONTEND_PORT=80
BACKEND_PORT=3000

# ======== DOCKER BUILD ========
# Enable BuildKit for better layer cache reuse in CI
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1