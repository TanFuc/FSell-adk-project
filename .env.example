# ======== POSTGRES CONFIG ========
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_postgres_password
POSTGRES_DB=adk_db

# ======== REDIS CONFIG ========
REDIS_PASSWORD=your_strong_redis_password

# ======== BACKEND CONFIG ========
# Used for backend CORS and JWT
FRONTEND_URL=https://www.sieuthithuocadk.com
FRONTEND_URLS=https://www.sieuthithuocadk.com
ENCRYPTION_KEY=your-32-character-encryption-key-for-prod
JWT_SECRET=your-jwt-secret-key-for-prod-secure-random

# ======== CLOUDFLARE R2 (UPLOAD) ========
R2_REGION=auto
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_KEY=your_r2_access_key
R2_SECRET=your_r2_secret_key
R2_BUCKET=my-app-images
R2_PUBLIC_URL=https://cdn.yourdomain.com

# ======== IMAGE OPTIMIZATION ========
IMAGE_MAX_WIDTH=2560
IMAGE_QUALITY=88

# ======== DOCKER PORTS ========
# Public ports exposed on host machine
FRONTEND_PORT=11111
BACKEND_PORT=9999
BACKEND_INTERNAL_PORT=9999
PROMETHEUS_PORT=9090
GRAFANA_PORT=3100

# Frontend build-time API endpoint
VITE_API_URL=https://www.sieuthithuocadk.com/api
VITE_GA_ID=

# ======== MONITORING ========
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_now

# ======== DOCKER BUILD ========
# Enable BuildKit for better layer cache reuse in CI
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1