# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/adk_db?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_strong_redis_password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Redirect URL after registration (optional)
REDIRECT_URL=

# Encryption (32 characters)
ENCRYPTION_KEY=your-32-character-encryption-key

# JWT
JWT_SECRET=your-jwt-secret-key-2024
JWT_EXPIRES_IN=86400

# Server
PORT=3000

# Cloudflare R2 (Image Upload)
R2_REGION=auto
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_KEY=your_r2_access_key
R2_SECRET=your_r2_secret_key
R2_BUCKET=my-app-images
R2_PUBLIC_URL=https://cdn.yourdomain.com

# Image Optimization
IMAGE_MAX_WIDTH=2560
IMAGE_QUALITY=88
